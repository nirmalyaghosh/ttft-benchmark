# Uncomment accordingly

# For provider, OpenRouter
# OPENAI_BASE_URL = https://openrouter.ai/api/v1
# OPENAI_API_KEY = your-api-key
# MODEL = anthropic/claude-sonnet-4.5

# For provider, Azure OpenAI
# OPENAI_BASE_URL = https://<your-resource-name>.openai.azure.com/openai/v1/
# OPENAI_API_KEY = your-api-key-get-it-from-Microsoft-Foundry
# MODEL = gpt-4.1-nano
# RESOURCE_NAME = your-resource-name
# AZURE_DEPLOYMENT = gpt-4.1-nano
# MODEL_ENDPOINT_DEPLOYMENT_REGION = <Azure-region-name>
# API_VERSION=2025-01-01-preview

# Legacy OpenRouter key (for backward compatibility)
OPENROUTER_API_KEY=${OPENAI_API_KEY}

# Other configurations
ITERATIONS_PER_SIZE = 10
LOG_FILE_PATH = /path/to/ttft_benchmark_data.jsonl
PROMPT_SIZES = 100,500,1000,2000,5000
SLEEP_SECONDS_BETWEEN_REQUESTS = 15
